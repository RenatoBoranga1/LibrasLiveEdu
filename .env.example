APP_NAME=LibrasLive Edu
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://libraslive:libraslive@localhost:5432/libraslive
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEMO_MODE=true
SECRET_KEY=change-me-use-a-long-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CLASS_JOIN_TOKEN_EXPIRE_HOURS=8
TRANSCRIPT_RETENTION_DAYS=30
VLIBRAS_API_URL=
VLIBRAS_API_KEY=
TRUSTED_DICTIONARY_SOURCES=VLibras
AI_SUMMARY_ENABLED=false
AI_PROVIDER=local
AI_MODEL=
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1/chat/completions
SUMMARY_INTERVAL_SECONDS=45
SUMMARY_MIN_SEGMENTS=3
SUMMARY_MAX_SEGMENTS=20
INES_MEDIA_IMPORT_AUTHORIZED=false
INES_MEDIA_AUTHORIZATION_REFERENCE=
